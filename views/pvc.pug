extends base

mixin serviceCard(name, price, img)
  .service-card
    img(src="/static/images/" + img)
    .info
      h3 #{name}
      p ₹#{price}

    .actions
      button.add-btn(onclick=`addAndPay('${name}', ${price})`) Add

      .qty-control(id=`control-${name}`)
        button.minus(onclick=`changeQty('${name}', -1)`) −
        span.qty(id=`qty-${name}`) 0
        button.plus(onclick=`changeQty('${name}', 1)`) +

block styles
  link(rel="stylesheet", href="../static/electrician.css")

block content
  .service-page

    // ===== SIDEBAR =====
    .service-sidebar
      h3 Select PVC Service

      .sidebar-grid
        .side-item(onclick="filterService('pipe')")
          img(src="/static/images/pipe.jpg")
          span Pipe Work

        .side-item(onclick="filterService('fitting')")
          img(src="/static/images/tap.jpg")
          span Fitting

        .side-item(onclick="filterService('leak')")
          img(src="/static/images/leak.jpg")
          span Leak Repair

    // ===== MAIN =====
    .service-main
      h1 PVC Services 🔧

      // PIPE
      .service-group(data-category="pipe")
        +serviceCard("Pipe Installation", 299, "pipe.jpg")
        +serviceCard("Pipe Replacement", 249, "pipe.jpg")

      // FITTING
      .service-group(data-category="fitting")
        +serviceCard("Tap Fitting", 149, "tap.jpg")
        +serviceCard("Shower Installation", 199, "shower.avif")

      // LEAK
      .service-group(data-category="leak")
        +serviceCard("Leak Fix", 199, "leak.jpg")
        +serviceCard("Joint Repair", 149, "leak.jpg")

    // ===== RIGHT SIDE =====
    .service-right

      .cart-box
        h3 Cart
        ul#cart-items
        p.total Total: ₹0
        button.pay-btn(onclick="goToCheckout()") Proceed to Pay

      .info-box
        h4 Why choose us?
        ul
          li ✔ Expert Technicians
          li ✔ Quick Service
          li ✔ Affordable Rates

      .info-box
        h4 Safety Promise
        ul
          li ✔ Verified Workers
          li ✔ Safe Installation
          li ✔ Service Warranty

block scripts
  script(src="../static/electrician.js")

  script.
    function goToCheckout() {
        if (Object.keys(cart).length === 0) {
            alert("Cart is empty!");
            return;
        }

        localStorage.setItem("cart", JSON.stringify(cart));
        window.location.href = "/checkout";
    }