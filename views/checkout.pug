extends base

block styles
  link(rel="stylesheet", href="../static/checkout.css")

block content
  .checkout-page

    // ===== LEFT SIDE =====
    .checkout-left

      // LOGIN BOX
      .login-box
        h3 Account
        p To continue, please login
        button.login-btn(onclick="goToProfile()") Login / Sign Up

      // ADDRESS BOX
      .address-box
        h3 Service Address

        // VIEW MODE
        .address-card#addressView
          h4#addrName Rahul Sharma
          p#addrAddress 123, Delhi, India
          p#addrPhone +91 9876543210

        button.change-btn(onclick="enableAddressEdit()") Change Address

        // EDIT MODE (hidden by default)
        .address-form#addressForm(style="display:none; margin-top:10px;")
          input(type="text" id="editName" placeholder="Full Name")
          input(type="text" id="editPhone" placeholder="Phone Number")
          textarea(id="editAddress" placeholder="Full Address")

          button.save-btn(onclick="saveAddress()") Save Address

    // ===== RIGHT SIDE =====
    .checkout-right

      .summary-box
        h3 Payment Summary

        .item
          span AC Service (2 items)
          span ₹1,098

        .item
          span Discount
          span.green -₹100

        .item
          span Taxes & Fees
          span ₹89

        hr

        .total
          span Total Amount
          span ₹1,187

        button.pay-btn(onclick="openPayment()") Proceed to Pay

      // PAYMENT METHODS
      .payment-box#paymentBox
        h3 Select Payment Method

        label.method
          input(type="radio" name="pay" checked)
          span UPI (Google Pay / PhonePe)

        label.method
          input(type="radio" name="pay")
          span Credit / Debit Card

        label.method
          input(type="radio" name="pay")
          span Net Banking

        label.method
          input(type="radio" name="pay")
          span Cash on Service

        button.final-pay(onclick="payNow()") Pay Now

block scripts
  script(src="../static/checkout.js")
  script.
    function goToProfile() {
      window.location.href = "/profile";
    }