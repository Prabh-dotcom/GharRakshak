extends base

mixin serviceCard(name, price, img)
  .service-card
    img(src="/static/images/" + img)
    .info
      h3 #{name}
      p ₹#{price}

    .actions
      button.add-btn(onclick=`addAndPay('${name}', ${price})`) Add

      .qty-control(id=`control-${name}`)
        button.minus(onclick=`changeQty('${name}', -1)`) −
        span.qty(id=`qty-${name}`) 0
        button.plus(onclick=`changeQty('${name}', 1)`) +

block styles
  link(rel="stylesheet", href="../static/electrician.css")

block content
  .service-page

    // ===== SIDEBAR =====
    .service-sidebar
      h3 Select a service

      .sidebar-grid
        .side-item(onclick="filterService('pvc')")
          img(src="/static/images/pvc.jpg")
          span PVC Panels

        .side-item(onclick="filterService('wallpaper')")
          img(src="/static/images/wallpaper.jpg")
          span Wallpaper

        .side-item(onclick="filterService('design')")
          img(src="/static/images/design.jpg")
          span Wall Design

    // ===== MAIN =====
    .service-main
      h1 Wallpaper & PVC Services 🧱

      // PVC
      .service-group(data-category="pvc")
        +serviceCard("PVC Wall Panel Install", 499, "pvc.jpg")
        +serviceCard("PVC Ceiling Setup", 699, "pvc.jpg")

      // WALLPAPER
      .service-group(data-category="wallpaper")
        +serviceCard("Wallpaper Installation", 399, "wallpaper.jpg")
        +serviceCard("Wallpaper Removal", 199, "wallpaper.jpg")

      // DESIGN
      .service-group(data-category="design")
        +serviceCard("3D Wall Design", 999, "design.jpg")
        +serviceCard("Custom Wall Decor", 1299, "design.jpg")

    // ===== RIGHT SIDE =====
    .service-right

      .cart-box
        h3 Cart
        ul#cart-items
        p.total Total: ₹0
        button.pay-btn(onclick="goToCheckout()") Proceed to Pay

      .info-box
        h4 Why choose us?
        ul
          li ✔ Premium Materials
          li ✔ Expert Designers
          li ✔ Fast Installation

      .info-box
        h4 Safety Promise
        ul
          li ✔ Clean Work
          li ✔ No Damage Guarantee
          li ✔ Service Warranty

block scripts
  script(src="../static/electrician.js")

  script.
    function goToCheckout() {
        if (Object.keys(cart).length === 0) {
            alert("Cart is empty!");
            return;
        }

        localStorage.setItem("cart", JSON.stringify(cart));
        window.location.href = "/checkout";
    }