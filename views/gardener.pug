extends base

mixin serviceCard(name, price, img)
  .service-card
    img(src="/static/images/" + img)
    .info
      h3 #{name}
      p ₹#{price}

    .actions
      button.add-btn(onclick=`addAndPay('${name}', ${price})`) Add

      .qty-control(id=`control-${name}`)
        button.minus(onclick=`changeQty('${name}', -1)`) −
        span.qty(id=`qty-${name}`) 0
        button.plus(onclick=`changeQty('${name}', 1)`) +

block styles
  link(rel="stylesheet", href="../static/electrician.css")

block content
  .service-page

    // ===== SIDEBAR =====
    .service-sidebar
      h3 Select a service

      .sidebar-grid
        .side-item(onclick="filterService('plants')")
          img(src="/static/images/plants.avif")
          span Plants

        .side-item(onclick="filterService('lawn')")
          img(src="/static/images/lawn.avif")
          span Lawn

        .side-item(onclick="filterService('watering')")
          img(src="/static/images/watering.avif")
          span Watering

        .side-item(onclick="filterService('cleaning')")
          img(src="/static/images/garden-clean.avif")
          span Cleaning

    // ===== MAIN =====
    .service-main
      h1 Gardener Services 🌱

      // PLANTS
      .service-group(data-category="plants")
        +serviceCard("Plant Setup", 199, "plants.avif")
        +serviceCard("Pot Replacement", 149, "pot.avif")

      // LAWN
      .service-group(data-category="lawn")
        +serviceCard("Grass Cutting", 299, "grass.avif")
        +serviceCard("Lawn Maintenance", 399, "lawn.avif")

      // WATERING
      .service-group(data-category="watering")
        +serviceCard("Daily Watering", 199, "watering.avif")
        +serviceCard("Drip Irrigation Setup", 499, "drip-irrigation.avif")

      // CLEANING
      .service-group(data-category="cleaning")
        +serviceCard("Garden Cleaning", 249, "garden-clean.avif")
        +serviceCard("Leaf Removal", 149, "leaf-removal.avif")

    // ===== RIGHT SIDE =====
    .service-right

      .cart-box
        h3 Cart
        ul#cart-items
        p.total Total: ₹0
        button.pay-btn(onclick="goToCheckout()") Proceed to Pay

      .info-box
        h4 Why choose us?
        ul
          li ✔ Verified Gardeners
          li ✔ Eco-Friendly Service
          li ✔ Affordable Pricing

      .info-box
        h4 Safety Promise
        ul
          li ✔ Background Checked
          li ✔ Safe Equipment
          li ✔ Service Warranty

block scripts
  script(src="../static/electrician.js")

  script.
    function goToCheckout() {
        if (Object.keys(cart).length === 0) {
            alert("Cart is empty!");
            return;
        }

        localStorage.setItem("cart", JSON.stringify(cart));
        window.location.href = "/checkout";
    }