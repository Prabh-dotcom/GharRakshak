extends base

mixin serviceCard(name, price, img)
  .service-card
    img(src="/static/images/" + img)
    .info
      h3 #{name}
      p ₹#{price}

    .actions
      button.add-btn(onclick=`addAndPay('${name}', ${price})`) Add

      .qty-control(id=`control-${name}`)
        button.minus(onclick=`changeQty('${name}', -1)`) −
        span.qty(id=`qty-${name}`) 0
        button.plus(onclick=`changeQty('${name}', 1)`) +

block styles
  link(rel="stylesheet", href="../static/electrician.css")

block content
  .service-page

    // ===== SIDEBAR =====
    .service-sidebar
      h3 Select a service

      .sidebar-grid
        .side-item(onclick="filterService('wall')")
          img(src="/static/images/wall-paint.avif")
          span Wall Paint

        .side-item(onclick="filterService('texture')")
          img(src="/static/images/paint-texture.avif")
          span Texture

        .side-item(onclick="filterService('polish')")
          img(src="/static/images/wood-polish.avif")
          span Polish

        .side-item(onclick="filterService('waterproof')")
          img(src="/static/images/terrace-waterproofing.avif")
          span Waterproofing

    // ===== MAIN =====
    .service-main
      h1 Painter 🎨

      // WALL PAINT
      .service-group(data-category="wall")
        +serviceCard("1 Room Paint", 999, "wall-paint.avif")
        +serviceCard("Full House Paint", 4999, "full-house-paint.avif")

      // TEXTURE
      .service-group(data-category="texture")
        +serviceCard("Designer Texture", 1499, "paint-texture.avif")
        +serviceCard("Wall Design Paint", 1999, "wall-design-paint.avif")

      // POLISH
      .service-group(data-category="polish")
        +serviceCard("Wood Polish", 799, "wood-polish.avif")
        +serviceCard("Furniture Polish", 999, "furniture-polish.avif")

      // WATERPROOF
      .service-group(data-category="waterproof")
        +serviceCard("Terrace Waterproof", 2999, "terrace-waterproofing.avif")
        +serviceCard("Wall Leakage Fix", 1999, "wall-fix-leakage.avif")

    // ===== RIGHT SIDE =====
    .service-right

      .cart-box
        h3 Cart
        ul#cart-items
        p.total Total: ₹0
        button.pay-btn(onclick="goToCheckout()") Proceed to Pay

      .info-box
        h4 Why choose us?
        ul
          li ✔ Verified Painters
          li ✔ Fast Service
          li ✔ Affordable Pricing

      .info-box
        h4 Safety Promise
        ul
          li ✔ Background Checked
          li ✔ Clean Work
          li ✔ Service Warranty

block scripts
  script(src="../static/electrician.js")

  script.
    function goToCheckout() {
        if (Object.keys(cart).length === 0) {
            alert("Cart is empty!");
            return;
        }

        localStorage.setItem("cart", JSON.stringify(cart));
        window.location.href = "/checkout";
    }